# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Local dev — use SQLite (override in Docker via .env)
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email - Primary SMTP (Default: Hotmail/Outlook)
# NOTE: If 2-Step Verification is enabled, you MUST use a Microsoft App Password.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=humorphic.labs@hotmail.com
EMAIL_HOST_PASSWORD=your-microsoft-app-password
DEFAULT_FROM_EMAIL=humorphic.labs@hotmail.com

# Email - Secondary SMTP (Gmail)
# NOTE: Gmail requires 2-Step Verification & a Google App Password (not your account password).
SECONDARY_EMAIL_HOST=smtp.gmail.com
SECONDARY_EMAIL_PORT=587
SECONDARY_EMAIL_USE_TLS=True
SECONDARY_EMAIL_HOST_USER=humorphic.labs@gmail.com
SECONDARY_EMAIL_HOST_PASSWORD=your-google-app-password
SECONDARY_DEFAULT_FROM_EMAIL=humorphic.labs@gmail.com


# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# MinIO / S3 (set USE_S3=True in Docker)
USE_S3=False
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=humorphic

# Optional AI / OAuth / Phase 3
OPENAI_API_KEY=
GEMINI_API_KEY=
FRONTEND_URL=http://localhost:3000
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Resend HTTP API (Bypasses Render SMTP port blocking)
RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev  # Keep commented out to use category routing (notifications@, tasks@, etc.)
SECONDARY_RESEND_API_KEY=
# SECONDARY_RESEND_FROM_EMAIL=onboarding@resend.dev
FRONTEND_EMAIL_SECRET=your-frontend-email-secret-token
